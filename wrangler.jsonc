{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "todayssoftwaredeveloper",
  "compatibility_date": "2025-09-27",
  "main": "worker.js",
  "assets": { "directory": "dist", "binding": "ASSETS" },
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "ai": {
    "binding": "AI"
  }
}
