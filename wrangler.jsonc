{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "jeremylankford",
  "compatibility_date": "2025-09-27",
  "main": "worker.js",
  "assets": { "directory": "dist", "binding": "ASSETS" },
  "observability": {
    "enabled": true
  },
  "routes": [
    { "pattern": "jeremylankford.com", "custom_domain": true },
    { "pattern": "www.jeremylankford.com", "custom_domain": true }
  ],
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "ai": {
    "binding": "AI"
  }
}
